# Required for private Hugging Face model repos.
HF_TOKEN=hf_your_token_here

# Server.
HOST=0.0.0.0
PORT=8080
DEVICE=cpu
TMP_AUDIO_DIR=/tmp/audio_outputs
TMP_AUDIO_MAX_AGE_SECONDS=3600

# Translation backend: gguf or hf_lora.
LLM_BACKEND=gguf
TRANSLATION_MODELS=gemma_gguf,llama_lora
DEFAULT_TRANSLATION_MODEL=gemma_gguf
LLM_MAX_NEW_TOKENS=256
LLM_TEMPERATURE=0.1

# GGUF from Hugging Face.
LLM_GGUF_REPO_ID=your-org/hindi-haryanvi-gguf
LLM_GGUF_FILENAME=gemma-4-E4B-it-Q4_K_S.gguf
LLM_GGUF_CHAT_FORMAT=gemma
LLM_GGUF_N_CTX=2048
LLM_GGUF_N_THREADS=8
LLM_GGUF_N_GPU_LAYERS=0

# Alternative: Transformers base model plus PEFT/LoRA adapter.
# Set LLM_BACKEND=hf_lora to use these.
LLM_HF_BASE_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_HF_ADAPTER_ID=your-org/hindi-haryanvi-lora
LLM_LOAD_IN_4BIT=true

# Frontend/API selectable LoRA profile.
LLM_LORA_BASE_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_LORA_ADAPTER_ID=Satyam-Srivastava/hindi-to-haryanvi-translation-llama3-qlora
LLM_LORA_SYSTEM_PROMPT=You are a precise Hindi to Haryanvi (Bangru) translator. Convert the standard Hindi input into grammatically correct Haryanvi. Follow systematic lexical substitutions and morpho-syntactic rules.

# TTS backend: vits or xtts.
TTS_BACKEND=vits

# Required by some Coqui XTTS-v2 flows. Only set this after you have reviewed
# the model license and your college/project use is allowed.
# COQUI_TOS_AGREED=1

# VITS checkpoint and config from Hugging Face.
TTS_REPO_ID=your-org/haryanvi-vits
TTS_CHECKPOINT_FILENAME=best_model_16731.pth
TTS_CONFIG_FILENAME=config.json

# Alternative: XTTS-v2 from Hugging Face.
# Set TTS_BACKEND=xtts to use these.
# XTTS_LOADER=api works for stock XTTS and most uploaded checkpoints.
# XTTS_LOADER=native uses the direct XTTS-v2 loader if your fine-tuned repo
# needs explicit checkpoint/vocab/speakers loading.
XTTS_LOADER=api
XTTS_REPO_ID=coqui/XTTS-v2
XTTS_CHECKPOINT_FILENAME=model.pth
XTTS_CONFIG_FILENAME=config.json
XTTS_VOCAB_FILENAME=vocab.json
XTTS_SPEAKERS_FILENAME=speakers_xtts.pth
XTTS_DVAE_FILENAME=dvae.pth
XTTS_MEL_STATS_FILENAME=mel_stats.pth
XTTS_LANGUAGE=hi
XTTS_GPT_COND_LEN=3
XTTS_TEMPERATURE=0.75
XTTS_SPEED=1.0
XTTS_USE_DEEPSPEED=false

# Speaker reference can be in XTTS_REPO_ID, a separate repo, or local disk.
XTTS_SPEAKER_WAV_FILENAME=samples/en_sample.wav
# XTTS_SPEAKER_WAV_REPO_ID=your-org/haryanvi-speaker-refs
# XTTS_SPEAKER_WAV_PATH=/app/reference.wav

# Alternative local fine-tuned XTTS-v2 artifact sources.
# XTTS_MODEL_DIR=/app/xtts_finetuned
# XTTS_CHECKPOINT_PATH=/app/xtts_finetuned/model.pth
# XTTS_CONFIG_PATH=/app/xtts_finetuned/config.json
# XTTS_VOCAB_PATH=/app/xtts_finetuned/vocab.json
# XTTS_SPEAKERS_PATH=/app/xtts_finetuned/speakers_xtts.pth
